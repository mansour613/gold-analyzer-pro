PORT=8080
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini

# Recommended for accurate spot XAUUSD candles used by Home, Signals, Levels and Analysis.
# Twelve Data symbol used in code: XAU/USD
TWELVE_DATA_API_KEY=

# Optional validators for spot XAUUSD quotes. These are used to reject bad/outlier prices.
# GoldAPI keys often start with sk_. Put them here, not in TWELVE_DATA_API_KEY.
GOLDAPI_KEY=
ALPHA_VANTAGE_API_KEY=

# Safety guard for XAUUSD spot prices. Adjust only if market regime changes.
XAUUSD_MIN_VALID=1000
XAUUSD_MAX_VALID=10000
XAUUSD_MAX_FEED_DEVIATION_PCT=1.0
FALLBACK_XAUUSD_PRICE=4540

# Emergency only. Disabled by default because Yahoo can return wrong XAUUSD values.
ALLOW_YAHOO_SPOT_FALLBACK=false

# Keep false in production. Real candles must come from Twelve Data.
ALLOW_SYNTHETIC_CANDLE_FALLBACK=false
